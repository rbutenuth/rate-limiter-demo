http://www.mulesoft.org/schema/mule/ee/core http://www.mulesoft.org/schema/mule/ee/core/current/mule-ee.xsd">

	<munit:config name="fixed-delay-suite.xml"/>

	<rate-limiter:rate-limiter-config name="Rate_limiter_unbounded_100ms" minTimeBetweenOperations="100" unit="MILLISECONDS" doc:name="Unbounded">
		<rate-limiter:buffer-ops >
			<rate-limiter:unbounded-buffer />
		</rate-limiter:buffer-ops>
	</rate-limiter:rate-limiter-config>

	<rate-limiter:rate-limiter-config name="Rate_limiter_bounded_100ms_buffer_2" minTimeBetweenOperations="100" unit="MILLISECONDS" doc:name="Bounded, size 2">
		<rate-limiter:buffer-ops >
			<rate-limiter:bounded-buffer bufferSize="2" />
		</rate-limiter:buffer-ops>
	</rate-limiter:rate-limiter-config>

	<munit:test description="Test" doc:id="2f359441-7227-4aa4-bcf7-676d9e0f0889" name="fixed-delay-1">
		<munit:execution>
			<ee:transform doc:name="set var start to millis" doc:id="aab9de81-7f97-4b06-bdf4-f0ffe796cc49">
				<ee:message>
					<ee:set-payload><![CDATA[%dw 2.0
output application/java
---
{
}]]></ee:set-payload>
				</ee:message>
				<ee:variables>
					<ee:set-variable variableName="start"><![CDATA[%dw 2.0
output application/java
import * from dw::util::Timer
---
currentMilliseconds()
]]></ee:set-variable>
				</ee:variables>
			</ee:transform>
			<rate-limiter:fixed-delay delay="1" doc:id="021dac68-6a74-4236-8ca4-ffa0d368a8de" doc:name="1 ms" unit="MILLISECONDS" />
			<ee:transform doc:name="set var finish to millis" doc:id="ead4bc43-83c3-4556-8e7c-3cde39d7222b">
				<ee:message>
					<ee:set-payload><![CDATA[%dw 2.0
output application/java
---
{
}]]></ee:set-payload>
				</ee:message>
				<ee:variables>
					<ee:set-variable variableName="finish"><![CDATA[%dw 2.0
output application/java
import * from dw::util::Timer
---
currentMilliseconds()
]]></ee:set-variable>
				</ee:variables>
			</ee:transform>
		</munit:execution>
		<munit:validation>
			<munit-tools:assert doc:name="less than 100ms" doc:id="bd07a4b2-f634-43ba-8bb2-47979f46c7bd" message="Too slow" >
				<munit-tools:that ><![CDATA[#[import * from dw::test::Asserts 
 ---
(vars.finish - vars.start) must beLowerThan(100)]]]></munit-tools:that>
			</munit-tools:assert>
		</munit:validation>
	</munit:test>
