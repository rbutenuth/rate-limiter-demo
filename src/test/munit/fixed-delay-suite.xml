	<munit:test name="rate-limit-unbounded-buffer" doc:id="9279b627-d7bf-447e-a4f4-432d61411f52" >
		<munit:execution >
			<ee:transform doc:name="a: currentMilliseconds()" doc:id="2750f343-db13-443c-82a2-f5bc50d8051a" >
				<ee:message >
					<ee:set-payload ><![CDATA[%dw 2.0

output application/java

import * from dw::util::Timer

---

{

	a: currentMilliseconds()

}]]></ee:set-payload>
				</ee:message>
			</ee:transform>
			<rate-limiter:limit-rate doc:name="100ms" doc:id="fc891309-e775-4329-a5c4-41ce228f41e0" config-ref="Rate_limiter_unbounded_100ms" />
			<ee:transform doc:name="payload ++ b: currentMilliseconds()" doc:id="4d6b97b5-cd7a-4737-9f94-f3d2747e2efb" >
				<ee:message >
					<ee:set-payload ><![CDATA[%dw 2.0

output application/java

import * from dw::util::Timer

---

payload ++ {

	b: currentMilliseconds()

}]]></ee:set-payload>
				</ee:message>
			</ee:transform>
			<rate-limiter:limit-rate doc:name="100ms1" doc:id="be7796f1-7a55-42e0-9138-67584439a105" config-ref="Rate_limiter_unbounded_100ms" />
			<ee:transform doc:name="payload ++ c: currentMilliseconds()" doc:id="1846464f-f44a-4c33-be9b-f9510593e49f" >
				<ee:message >
					<ee:set-payload ><![CDATA[%dw 2.0

output application/java

import * from dw::util::Timer

---

payload ++ {

	c: currentMilliseconds()

}]]></ee:set-payload>
				</ee:message>
			</ee:transform>
			<rate-limiter:limit-rate doc:name="100ms2" doc:id="3c5b1669-97c3-4cd5-b611-815302ec811d" config-ref="Rate_limiter_unbounded_100ms" />
			<ee:transform doc:name="payload ++ d: currentMilliseconds()" doc:id="58c84192-4f98-4385-966f-06365d63a7f8" >
				<ee:message >
					<ee:set-payload ><![CDATA[%dw 2.0

output application/java

import * from dw::util::Timer

---

payload ++ {

	d: currentMilliseconds()

}]]></ee:set-payload>
				</ee:message>
			</ee:transform>
			<set-payload value="#[%dw 2.0&#10;&#10;output application/java&#10;&#10;import * from dw::util::Timer&#10;&#10;---&#10;&#10;payload ++ {&#10;&#10;	d: currentMilliseconds()&#10;&#10;}]" doc:name="payload ++ d: currentMilliseconds()" doc:id="603bd7a8-68f4-4d1d-a730-40a2ddb04ce3" />
		</munit:execution>
		<munit:validation >
			<munit-tools:assert-that doc:name="a -&gt; b" doc:id="3c7e0082-bbba-4a6c-a31a-3c36b13112d8" message="a -&gt;  b" expression="#[payload.b - payload.a]" is="#[MunitTools::lessThan(50)]"/>
			<munit-tools:assert-that doc:name="b -&gt; c" doc:id="fc7972e4-cb38-4d36-8984-0501af9d27d7" message="b -&gt; c" expression="#[payload.c - payload.b]" is="#[MunitTools::greaterThan(90)]" />
			<munit-tools:assert-that doc:name="c -&gt; d" doc:id="87b9a9c3-f6b8-401a-949f-d89dae983b2d" message="c -&gt; d" expression="#[payload.d - payload.c]" is="#[MunitTools::greaterThan(90)]" />
		</munit:validation>
	</munit:test>

	<munit:test name="test-ratelimit-overflow-error" doc:id="5263b2f6-5910-4f74-866b-6b7483726b96" >
		<munit:execution >
			<try doc:name="Try" doc:id="df99eefe-01ec-456b-bee2-685abfbf9ca3" >
				<parallel-foreach doc:name="Parallel For Each" doc:id="02c61d66-9934-40bb-b156-b26c8670507a" collection="#[to(1, 10)]">
					<rate-limiter:limit-rate doc:name="Limit rate - Buffer " doc:id="af877f81-56b4-462c-9d3d-7f987ce731b1" config-ref="Rate_limiter_bounded_100ms_buffer_2" />
				</parallel-foreach>
				<set-payload value="OK" doc:name="OK" doc:id="cb188ca8-acc3-4291-8760-7de4f4288a9f" />
				<error-handler >
					<on-error-continue enableNotifications="false" logException="false" doc:name="On Error Continue2" doc:id="4bb51ae3-3f98-48c4-943a-b2dd8afdd358" type="*:*">
						<set-payload value="ERROR" doc:name="ERROR" doc:id="b4fbcaf0-96a0-426b-84ba-000474e9494f" />
					</on-error-continue>
				</error-handler>
			</try>
		</munit:execution>
		<munit:validation >
			<munit-tools:assert-equals doc:name="ERROR" doc:id="d9aae330-1234-4d0c-8521-1fe182c965a2" actual="#[payload]" expected="ERROR" message="Missing error"/>
		</munit:validation>
	</munit:test>

</mule>